apptainer {
    enabled = true
    autoMounts = true
    pullTimeout = '24h'
    cacheDir = "$projectDir/apptainer_images"
    // runOptions = "--bind /home/masakazu" // 必要であればホストのパスをマウント
}

process {
    // 全プロセスでこのコンテナイメージを使う設定
    // ※ 絶対パスで指定すると間違いがないです
    container = "$projectDir/rnaseq_tools.sif"
    
    // エラー時の挙動（任意）
    errorStrategy = 'finish'
}
